# API Configuration
# Replace these values with your production URLs when deploying

# Main Backend API (Node.js)
EXPO_PUBLIC_API_URL=http://YOUR_IP:5000/api

# Gait Analysis Service (Python Flask)
EXPO_PUBLIC_GAIT_API_URL=http://YOUR_IP:5001

# Therapy Exercises Service (Python Flask)
EXPO_PUBLIC_THERAPY_API_URL=http://YOUR_IP:5002

# Firebase Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
